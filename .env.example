# GitHub Personal Access Token (required for higher rate limits)
# Generate at: https://github.com/settings/tokens
# Scopes needed: (no special scopes – public repo access only)
GITHUB_TOKEN=

# Crawler settings
CRAWLER_AUTO_START=false
CRAWLER_DELAY=2.0

# Admin password for /admin dashboard
ADMIN_PASSWORD=admin123

# Graph cache TTL in seconds
GRAPH_CACHE_TTL=30

# Database password (used in docker-compose)
POSTGRES_PASSWORD=change_me_to_a_strong_password

# CORS – add your Cloudflare tunnel domain
# CORS_ORIGINS=https://your-tunnel-domain.example.com

# Database (for local development – SQLite is used by default)
# DATABASE_URL=sqlite+aiosqlite:///./data/github_ai_network.db

# Database (for Docker Compose – set automatically in docker-compose.yml)
# DATABASE_URL=postgresql+asyncpg://postgres:<password>@db:5432/github_ai_network
